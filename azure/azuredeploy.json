{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "appName": {
      "type": "string",
      "defaultValue": "chimquiz",
      "maxLength": 32,
      "metadata": { "description": "Prefix utilisé pour nommer toutes les ressources." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Région Azure (ex: westeurope)." }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "ghcr.io/cblomart/chimquiz:latest",
      "metadata": { "description": "Image Docker à déployer." }
    },
    "minReplicas": {
      "type": "int",
      "defaultValue": 0,
      "metadata": { "description": "0 = scale-to-zero (le moins cher), 1 = toujours actif." }
    },
    "cosmosFreeTier": {
      "type": "bool",
      "defaultValue": false,
      "metadata": { "description": "Activer le free tier Cosmos DB (1 seul par abonnement)." }
    }
  },
  "variables": {
    "cosmosAccountName": "[toLower(concat('cosmos-', take(parameters('appName'), 10), '-', take(uniqueString(resourceGroup().id), 8)))]",
    "envName": "[concat('env-', parameters('appName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.DocumentDB/databaseAccounts",
      "apiVersion": "2023-04-15",
      "name": "[variables('cosmosAccountName')]",
      "location": "[parameters('location')]",
      "kind": "GlobalDocumentDB",
      "properties": {
        "databaseAccountOfferType": "Standard",
        "enableFreeTier": "[parameters('cosmosFreeTier')]",
        "capabilities": [{ "name": "EnableServerless" }],
        "locations": [
          {
            "locationName": "[parameters('location')]",
            "failoverPriority": 0
          }
        ],
        "consistencyPolicy": { "defaultConsistencyLevel": "Session" },
        "enableAutomaticFailover": false
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2023-05-01",
      "name": "[variables('envName')]",
      "location": "[parameters('location')]",
      "properties": {
        "zoneRedundant": false
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "[parameters('appName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('envName'))]",
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosAccountName'))]"
      ],
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('envName'))]",
        "configuration": {
          "secrets": [
            {
              "name": "cosmos-key",
              "value": "[listKeys(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosAccountName')), '2023-04-15').primaryMasterKey]"
            }
          ],
          "ingress": {
            "external": true,
            "targetPort": 8080,
            "transport": "auto",
            "allowInsecure": false
          }
        },
        "template": {
          "scale": {
            "minReplicas": "[parameters('minReplicas')]",
            "maxReplicas": 2,
            "rules": [
              {
                "name": "http-scaling",
                "http": {
                  "metadata": {
                    "concurrentRequests": "10"
                  }
                }
              }
            ]
          },
          "containers": [
            {
              "name": "[parameters('appName')]",
              "image": "[parameters('containerImage')]",
              "resources": {
                "cpu": 0.25,
                "memory": "0.5Gi"
              },
              "env": [
                {
                  "name": "ASPNETCORE_ENVIRONMENT",
                  "value": "Production"
                },
                {
                  "name": "CosmosDb__Endpoint",
                  "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosAccountName'))).documentEndpoint]"
                },
                {
                  "name": "CosmosDb__Key",
                  "secretRef": "cosmos-key"
                },
                {
                  "name": "CosmosDb__DatabaseName",
                  "value": "chimquiz"
                }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/",
                    "port": 8080
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 30
                }
              ]
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "appFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('appName'))).configuration.ingress.fqdn]"
    },
    "appUrl": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.App/containerApps', parameters('appName'))).configuration.ingress.fqdn)]"
    },
    "cosmosAccountName": {
      "type": "string",
      "value": "[variables('cosmosAccountName')]"
    },
    "cosmosEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosAccountName'))).documentEndpoint]"
    }
  }
}
